---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import GameGrid from '../components/GameGrid.astro'
import CategoryList from '../components/CategoryList.astro'
import Footer from '../components/Footer.astro'
import { sanityClient } from '../lib/sanity'
import { urlFor } from '../lib/sanityImage'

const [settings, featuredGames, categories] = await Promise.all([
  sanityClient.fetch(`*[_type == "siteSettings"][0]`),
  sanityClient.fetch(`
    *[_type == "game" && featured == true] | order(rating desc) {
      name,
      slug,
      tagline,
      rating,
      shortReview,
      affiliateUrl,
      logo,
      category->{ name, slug }
    }
  `),
  sanityClient.fetch(`
    *[_type == "category"] | order(name asc) {
      name,
      slug,
      description
    }
  `),
])

// Resolve logo URLs via @sanity/image-url (respects hotspot/crop)
const games = featuredGames.map((g: any) => ({
  ...g,
  logoUrl: g.logo ? urlFor(g.logo).width(112).height(112).fit('crop').auto('format').url() : undefined,
}))

const headline = settings?.heroHeadline ?? 'Skill-based games <em>that actually pay</em>'
const subhead = settings?.heroSubhead ?? 'We review and rank the top mobile games where your skill earns real cash rewards.'
const footerText = settings?.footerText
---
<Base
  title={settings?.siteName ? `${settings.siteName} — Skill-Based Cash Game Reviews` : undefined}
  description={settings?.heroSubhead ?? 'Expert reviews and rankings of the top mobile games where you can win real cash.'}
  canonical="https://mobilegameradar.com/"
>
  <Nav />
  <main>
    <Hero headline={headline} subhead={subhead} />
    <GameGrid games={games} />
    <CategoryList categories={categories} />
  </main>
  <Footer footerText={footerText} />
</Base>
