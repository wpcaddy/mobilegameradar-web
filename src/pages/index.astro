---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import CategoryRow from '../components/CategoryRow.astro'
import Footer from '../components/Footer.astro'
import { sanityClient } from '../lib/sanity'
import { urlFor } from '../lib/sanityImage'

const [settings, categoriesRaw, logoGames] = await Promise.all([
  sanityClient.fetch(`*[_type == "siteSettings"][0]`),
  sanityClient.fetch(`
    *[_type == "category"] | order(name asc) {
      name,
      slug,
      description,
      "games": *[_type == "game" && references(^._id)] | order(rating desc)[0...10] {
        name,
        slug,
        tagline,
        rating,
        affiliateUrl,
        logo
      }
    }
  `),
  sanityClient.fetch(`
    *[_type == "game" && defined(logo)] | order(rating desc)[0...30] {
      name,
      "logoUrl": logo.asset->url
    }
  `),
])

// Resolve logos for category row cards
const categories = categoriesRaw
  .filter((c: any) => c.games && c.games.length > 0)
  .map((c: any) => ({
    ...c,
    games: c.games.map((g: any) => ({
      ...g,
      logoUrl: g.logo
        ? urlFor(g.logo).width(96).height(96).fit('crop').auto('format').url()
        : undefined,
    })),
  }))

const headline = settings?.heroHeadline ?? 'Skill-based games <em>that actually pay</em>'
const subhead = settings?.heroSubhead ?? 'We review and rank the top mobile games where your skill earns real cash rewards.'
const footerText = settings?.footerText
---
<Base
  title={settings?.siteName ? `${settings.siteName} — Skill-Based Cash Game Reviews` : undefined}
  description={settings?.heroSubhead ?? 'Expert reviews and rankings of the top mobile games where you can win real cash.'}
  canonical="https://mobilegameradar.com/"
>
  <Nav />
  <main>
    <Hero
      headline={headline}
      subhead={subhead}
      logoTiles={logoGames}
      gameCount={logoGames.length > 0 ? 114 : 0}
      categoryCount={categories.length}
    />

    <section id="categories" aria-label="Browse by category">
      {categories.map((cat: any, i: number) => (
        <CategoryRow
          name={cat.name}
          slug={cat.slug}
          games={cat.games}
          index={i}
        />
      ))}
    </section>
  </main>
  <Footer footerText={footerText} />
</Base>
