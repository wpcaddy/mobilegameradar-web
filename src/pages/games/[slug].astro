---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { sanityClient } from '../../lib/sanity'
import { urlFor } from '../../lib/sanityImage'
import { toHTML } from '@portabletext/to-html'

export async function getStaticPaths() {
  const games = await sanityClient.fetch(`
    *[_type == "game"] { "slug": slug.current }
  `)
  return games.map((g: { slug: string }) => ({ params: { slug: g.slug } }))
}

const { slug } = Astro.params

const game = await sanityClient.fetch(`
  *[_type == "game" && slug.current == $slug][0] {
    name,
    slug,
    tagline,
    rating,
    shortReview,
    fullReview,
    affiliateUrl,
    logo,
    screenshots[] { asset-> },
    pros,
    cons,
    payoutMethod,
    platforms,
    publishedAt,
    category->{ name, slug }
  }
`, { slug })

if (!game) {
  return Astro.redirect('/404')
}

const logoUrl = game.logo
  ? urlFor(game.logo).width(160).height(160).fit('crop').auto('format').url()
  : null

const screenshotUrls: string[] = (game.screenshots ?? []).map((s: any) =>
  urlFor(s).width(800).height(500).fit('crop').auto('format').url()
)

const fullReviewHtml = game.fullReview
  ? toHTML(game.fullReview, { onMissingComponent: false })
  : null

const ratingDisplay = game.rating ? game.rating.toFixed(1) : null
const ratingPercent = game.rating ? (game.rating / 10) * 100 : 0
---
<Base
  title={`${game.name} Review — MobileGameRadar`}
  description={game.shortReview ?? `Our full review of ${game.name}.`}
>
  <Nav />

  <main>
    <!-- Hero / above-the-fold -->
    <section class="game-hero">
      <div class="container game-hero__inner">
        <div class="game-hero__left">
          {logoUrl
            ? <img class="game-hero__logo" src={logoUrl} alt={`${game.name} logo`} width="80" height="80" />
            : <div class="game-hero__logo-placeholder">{game.name[0]}</div>
          }
          <div class="game-hero__meta">
            {game.category && (
              <a href={`/categories/${game.category.slug.current}`} class="game-hero__cat eyebrow">
                {game.category.name}
              </a>
            )}
            <h1 class="game-hero__name">{game.name}</h1>
            {game.tagline && <p class="game-hero__tagline">{game.tagline}</p>}
          </div>
        </div>

        <div class="game-hero__right">
          {ratingDisplay && (
            <div class="game-hero__rating" aria-label={`Rating: ${ratingDisplay} out of 10`}>
              <span class="game-hero__rating-value">{ratingDisplay}</span>
              <span class="game-hero__rating-denom">/10</span>
              <div class="game-hero__rating-bar" role="presentation">
                <div class="game-hero__rating-fill" style={`width: ${ratingPercent}%`}></div>
              </div>
              <p class="game-hero__rating-label eyebrow">MGR Score</p>
            </div>
          )}
          <a
            href={game.affiliateUrl}
            target="_blank"
            rel="sponsored noopener"
            class="game-hero__cta"
          >
            Play {game.name}
          </a>
          {game.platforms && game.platforms.length > 0 && (
            <div class="game-hero__platforms">
              {game.platforms.map((p: string) => (
                <span class="badge">{p}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Body -->
    <div class="container game-body">

      <!-- Short review / intro -->
      {game.shortReview && (
        <p class="game-intro reveal">{game.shortReview}</p>
      )}

      <!-- Pros / Cons -->
      {(game.pros?.length > 0 || game.cons?.length > 0) && (
        <section class="proscons reveal" aria-label="Pros and cons">
          {game.pros?.length > 0 && (
            <div class="proscons__col proscons__col--pro">
              <p class="proscons__label eyebrow">Pros</p>
              <ul>
                {game.pros.map((item: string) => (
                  <li class="proscons__item proscons__item--pro">{item}</li>
                ))}
              </ul>
            </div>
          )}
          {game.cons?.length > 0 && (
            <div class="proscons__col proscons__col--con">
              <p class="proscons__label eyebrow">Cons</p>
              <ul>
                {game.cons.map((item: string) => (
                  <li class="proscons__item proscons__item--con">{item}</li>
                ))}
              </ul>
            </div>
          )}
        </section>
      )}

      <!-- Screenshots -->
      {screenshotUrls.length > 0 && (
        <section class="screenshots reveal" aria-label="Screenshots">
          <p class="eyebrow screenshots__label">Screenshots</p>
          <div class="screenshots__grid">
            {screenshotUrls.map((src, i) => (
              <img
                class="screenshots__img"
                src={src}
                alt={`${game.name} screenshot ${i + 1}`}
                loading="lazy"
                width="800"
                height="500"
              />
            ))}
          </div>
        </section>
      )}

      <!-- Full review -->
      {fullReviewHtml && (
        <section class="full-review reveal" aria-labelledby="full-review-heading">
          <p class="eyebrow">Full Review</p>
          <h2 id="full-review-heading" class="full-review__heading">Our verdict on {game.name}</h2>
          <div class="prose" set:html={fullReviewHtml} />
        </section>
      )}

      <!-- Details strip -->
      <section class="details reveal" aria-label="Game details">
        {game.payoutMethod && (
          <div class="details__item">
            <p class="details__label eyebrow">Payout Method</p>
            <p class="details__value">{game.payoutMethod}</p>
          </div>
        )}
        {game.platforms?.length > 0 && (
          <div class="details__item">
            <p class="details__label eyebrow">Platforms</p>
            <p class="details__value">{game.platforms.join(', ')}</p>
          </div>
        )}
        {game.category && (
          <div class="details__item">
            <p class="details__label eyebrow">Category</p>
            <p class="details__value">{game.category.name}</p>
          </div>
        )}
      </section>

      <!-- Bottom CTA -->
      <div class="bottom-cta reveal">
        <div class="bottom-cta__text">
          <p class="bottom-cta__heading">Ready to play?</p>
          <p class="bottom-cta__sub">Download {game.name} and start competing for real cash rewards.</p>
        </div>
        <a
          href={game.affiliateUrl}
          target="_blank"
          rel="sponsored noopener"
          class="bottom-cta__btn"
        >
          Play {game.name}
        </a>
      </div>

    </div>
  </main>

  <!-- Sticky mobile CTA -->
  <div class="sticky-cta" aria-hidden="true">
    <a
      href={game.affiliateUrl}
      target="_blank"
      rel="sponsored noopener"
      class="sticky-cta__btn"
    >
      Play {game.name}
    </a>
  </div>

  <Footer />
</Base>

<style>
  /* ── Hero ── */
  .game-hero {
    border-bottom: 1px solid var(--border);
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
    background: var(--surface);
  }

  .game-hero__inner {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .game-hero__left {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    flex: 1;
    min-width: 260px;
  }

  .game-hero__logo {
    width: 80px;
    height: 80px;
    border-radius: 18px;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .game-hero__logo-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 18px;
    background: var(--accent-light);
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .game-hero__meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.25rem;
  }

  .game-hero__cat {
    transition: color 0.15s;
  }
  .game-hero__cat:hover { color: var(--accent); }

  .game-hero__name {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
  }

  .game-hero__tagline {
    font-size: 1rem;
    color: var(--ink-secondary);
    max-width: 400px;
    line-height: 1.5;
  }

  .game-hero__right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    min-width: 200px;
  }

  .game-hero__rating {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 0.125rem;
  }

  .game-hero__rating-value {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--ink);
    line-height: 1;
  }

  .game-hero__rating-denom {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--ink-muted);
    align-self: flex-end;
    margin-bottom: 0.25rem;
  }

  .game-hero__rating-bar {
    width: 100%;
    flex-basis: 100%;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.375rem;
  }

  .game-hero__rating-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
  }

  .game-hero__rating-label {
    flex-basis: 100%;
    margin-top: 0.25rem;
  }

  .game-hero__cta {
    display: inline-block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--surface);
    background: var(--accent);
    padding: 0.875rem 2rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
  }

  .game-hero__cta:hover {
    background: var(--accent-dim);
    transform: translateY(-1px);
  }

  .game-hero__platforms {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink-secondary);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
  }

  /* ── Body ── */
  .game-body {
    padding-block: clamp(2.5rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    max-width: 800px;
  }

  .game-intro {
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    color: var(--ink-secondary);
    line-height: 1.7;
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
  }

  /* ── Pros / Cons ── */
  .proscons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .proscons__col {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }

  .proscons__col--pro { border-top: 3px solid #10b981; }
  .proscons__col--con { border-top: 3px solid #f43f5e; }

  .proscons__label {
    margin-bottom: 0.75rem;
  }

  .proscons__item {
    font-size: 0.9375rem;
    color: var(--ink);
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    line-height: 1.5;
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .proscons__item:last-child { border-bottom: none; }

  .proscons__item--pro::before {
    content: '+';
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #10b981;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .proscons__item--con::before {
    content: '–';
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #f43f5e;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  @media (max-width: 540px) {
    .proscons { grid-template-columns: 1fr; }
  }

  /* ── Screenshots ── */
  .screenshots__label { margin-bottom: 0.75rem; }

  .screenshots__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
    gap: 0.75rem;
  }

  .screenshots__img {
    width: 100%;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    object-fit: cover;
  }

  /* ── Full review prose ── */
  .full-review { display: flex; flex-direction: column; gap: 1rem; }

  .full-review__heading {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-top: 0.25rem;
  }

  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
  }

  .prose :global(h2),
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(h2) { font-size: 1.375rem; }
  .prose :global(h3) { font-size: 1.125rem; }

  .prose :global(p) { margin-bottom: 1rem; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(strong) { font-weight: 600; color: var(--ink); }
  .prose :global(em) { font-style: italic; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Details strip ── */
  .details {
    display: flex;
    gap: 1.5rem 3rem;
    flex-wrap: wrap;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .details__label { margin-bottom: 0.375rem; }

  .details__value {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
  }

  /* ── Bottom CTA ── */
  .bottom-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    background: var(--accent-light);
    border: 1px solid rgba(124, 58, 237, 0.2);
    border-radius: var(--radius);
    padding: 2rem;
  }

  .bottom-cta__heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .bottom-cta__sub {
    font-size: 0.9375rem;
    color: var(--ink-secondary);
  }

  .bottom-cta__btn {
    font-size: 1rem;
    font-weight: 600;
    color: var(--surface);
    background: var(--accent);
    padding: 0.875rem 2rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .bottom-cta__btn:hover {
    background: var(--accent-dim);
    transform: translateY(-1px);
  }

  /* ── Sticky mobile CTA ── */
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 0.75rem 1.25rem;
    background: rgba(250, 250, 247, 0.95);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--border);
  }

  .sticky-cta__btn {
    display: block;
    text-align: center;
    font-size: 1rem;
    font-weight: 600;
    color: var(--surface);
    background: var(--accent);
    padding: 0.875rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease;
  }

  .sticky-cta__btn:hover { background: var(--accent-dim); }

  @media (max-width: 640px) {
    .sticky-cta { display: block; }
    /* Pad body so content isn't hidden behind sticky bar */
    main { padding-bottom: 80px; }
  }
</style>
