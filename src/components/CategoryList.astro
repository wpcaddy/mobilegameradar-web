---
interface Category {
  name: string
  slug: { current: string }
  description?: string
}

interface Props {
  categories: Category[]
}
const { categories } = Astro.props
---
<section class="categories" id="categories" aria-labelledby="categories-heading">
  <div class="container">
    <div class="categories__header reveal">
      <p class="eyebrow">02 — Browse</p>
      <h2 id="categories-heading" class="categories__title">
        Find by <em>category</em>
      </h2>
    </div>

    {categories.length === 0 ? (
      <p class="categories__empty">Categories coming soon.</p>
    ) : (
      <ul class="categories__list" role="list">
        {categories.map((cat, i) => (
          <li class="reveal" style={`transition-delay: ${i * 50}ms`}>
            <a href={`/categories/${cat.slug.current}`} class="category-card">
              <div class="category-card__inner">
                <h3 class="category-card__name">{cat.name}</h3>
                {cat.description && (
                  <p class="category-card__desc">{cat.description}</p>
                )}
              </div>
              <span class="category-card__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .categories {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border);
  }

  .categories__header {
    margin-bottom: 2.5rem;
  }

  .categories__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
  }

  .categories__title em {
    font-style: italic;
    color: var(--accent);
  }

  .categories__empty {
    color: var(--ink-secondary);
    font-size: 0.9375rem;
    padding: 3rem 0;
  }

  .categories__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: 1rem;
  }

  .category-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .category-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .category-card:hover .category-card__arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  .category-card__inner {
    flex: 1;
    min-width: 0;
  }

  .category-card__name {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .category-card__desc {
    font-size: 0.8125rem;
    color: var(--ink-secondary);
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .category-card__arrow {
    font-size: 1.125rem;
    color: var(--ink-muted);
    flex-shrink: 0;
    transition: color 0.15s ease, transform 0.15s ease;
  }
</style>
