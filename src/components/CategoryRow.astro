---
interface Game {
  name: string
  slug: { current: string }
  tagline?: string
  rating?: number
  affiliateUrl: string
  logoUrl?: string
}

interface Props {
  name: string
  slug: { current: string }
  games: Game[]
  index: number
}

const { name, slug, games, index } = Astro.props
if (games.length === 0) return
---
<div class="cat-row reveal">
  <div class="cat-row__header">
    <div class="cat-row__meta">
      <p class="eyebrow">0{index + 1}</p>
      <h2 class="cat-row__title">
        <a href={`/categories/${slug.current}`}>{name}</a>
      </h2>
    </div>
    <a href={`/categories/${slug.current}`} class="cat-row__view-all">
      View all <span aria-hidden="true">→</span>
    </a>
  </div>

  <div class="cat-row__scroll-wrap">
    <ul class="cat-row__track" role="list">
      {games.map((game) => {
        const rating = game.rating ? game.rating.toFixed(1) : null
        return (
          <li class="cat-card">
            <div class="cat-card__inner">
              {/* Stretch link covers the whole card except the Play button */}
              <a href={`/games/${game.slug.current}`} class="cat-card__cover-link" aria-label={`Read ${game.name} review`} tabindex="-1" aria-hidden="true" />
              <div class="cat-card__logo-wrap">
                {game.logoUrl
                  ? <img class="cat-card__logo" src={game.logoUrl} alt={`${game.name} logo`} loading="lazy" width="56" height="56" />
                  : <div class="cat-card__logo-placeholder" aria-hidden="true">{game.name[0]}</div>
                }
              </div>
              <div class="cat-card__body">
                <p class="cat-card__name">
                  <a href={`/games/${game.slug.current}`} class="cat-card__name-link">{game.name}</a>
                </p>
                {game.tagline && <p class="cat-card__tagline">{game.tagline}</p>}
              </div>
              <div class="cat-card__footer">
                {rating && (
                  <div class="cat-card__rating">
                    <span class="cat-card__rating-value">{rating}</span>
                    <span class="cat-card__rating-label">/10</span>
                  </div>
                )}
                <a
                  href={game.affiliateUrl}
                  target="_blank"
                  rel="sponsored noopener"
                  class="cat-card__cta"
                  aria-label={`Play ${game.name}`}
                >
                  Play
                </a>
              </div>
            </div>
          </li>
        )
      })}
    </ul>
  </div>
</div>

<style>
  .cat-row {
    padding-block: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .cat-row__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-inline: var(--container-pad, 1.25rem);
  }

  @media (min-width: 768px) {
    .cat-row__header {
      padding-inline: max(1.25rem, calc((100vw - 1200px) / 2 + 1.25rem));
    }
  }

  .cat-row__meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cat-row__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.2;
  }

  .cat-row__title a {
    transition: color 0.15s ease;
  }

  .cat-row__title a:hover {
    color: var(--accent);
  }

  .cat-row__view-all {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    white-space: nowrap;
    transition: opacity 0.15s ease;
    padding-bottom: 2px;
  }

  .cat-row__view-all:hover {
    opacity: 0.7;
  }

  /* Horizontal scroll track */
  .cat-row__scroll-wrap {
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-inline: var(--container-pad, 1.25rem);
    padding-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    .cat-row__scroll-wrap {
      padding-inline: max(1.25rem, calc((100vw - 1200px) / 2 + 1.25rem));
    }
  }

  .cat-row__scroll-wrap::-webkit-scrollbar {
    display: none;
  }

  .cat-row__track {
    display: flex;
    flex-wrap: nowrap;
    gap: 1rem;
    width: max-content;
    align-items: flex-start;
  }

  /* Individual compact card */
  .cat-card {
    flex-shrink: 0;
    width: 200px;
  }

  .cat-card__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .cat-card__inner:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
    border-color: var(--border-hover);
  }

  /* Invisible overlay link makes the whole card clickable without nesting <a> tags */
  .cat-card__cover-link {
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    z-index: 0;
  }

  .cat-card__logo-wrap,
  .cat-card__body,
  .cat-card__footer {
    position: relative;
    z-index: 1;
  }

  .cat-card__name-link {
    color: inherit;
    text-decoration: none;
  }

  .cat-card__name-link:hover {
    color: var(--accent);
  }

  .cat-card__logo-wrap {
    flex-shrink: 0;
  }

  .cat-card__logo {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid var(--border);
    display: block;
  }

  .cat-card__logo-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--accent-light);
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cat-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .cat-card__name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cat-card__tagline {
    font-size: 0.75rem;
    color: var(--ink-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cat-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .cat-card__rating {
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
  }

  .cat-card__rating-value {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.03em;
  }

  .cat-card__rating-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--ink-muted);
  }

  .cat-card__cta {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .cat-card__cta:hover {
    background: var(--accent);
    color: white;
  }
</style>
