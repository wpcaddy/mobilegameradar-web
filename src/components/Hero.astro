---
interface Props {
  headline: string
  subhead: string
}
const { headline, subhead } = Astro.props
---
<section class="hero" aria-label="Hero">
  <div class="container hero__inner">
    <p class="eyebrow hero__eyebrow">Skill-based cash games — reviewed</p>
    <h1 class="hero__headline" set:html={headline} />
    <p class="hero__subhead">{subhead}</p>
    <div class="hero__actions">
      <a href="#featured" class="hero__btn-primary">See Top Games</a>
      <a href="#categories" class="hero__btn-secondary">Browse Categories</a>
    </div>
  </div>
  <div class="hero__decoration" aria-hidden="true">
    <div class="hero__blob"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 12vw, 9rem);
    border-bottom: 1px solid var(--border);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .hero__eyebrow {
    margin-bottom: 1.25rem;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 1.25rem;
  }

  /* Allow italic spans in the headline via set:html */
  .hero__headline :global(em) {
    font-style: italic;
    color: var(--accent);
  }

  .hero__subhead {
    font-size: clamp(1rem, 2.5vw, 1.1875rem);
    color: var(--ink-secondary);
    max-width: 520px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero__btn-primary {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--surface);
    background: var(--accent);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .hero__btn-primary:hover {
    background: var(--accent-dim);
    transform: translateY(-1px);
  }

  .hero__btn-secondary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
    background: transparent;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-hover);
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .hero__btn-secondary:hover {
    background: var(--border);
    border-color: transparent;
  }

  /* Decorative blob */
  .hero__decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__blob {
    position: absolute;
    right: -10%;
    top: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse at center, var(--accent-light) 0%, transparent 70%);
    opacity: 0.5;
    border-radius: 50%;
  }

  @media (max-width: 640px) {
    .hero__blob { display: none; }
  }
</style>
