---
---
<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label="MobileGameRadar home">
      <span class="nav__logo-mark">MGR</span>
      <span class="nav__logo-text">MobileGameRadar</span>
    </a>
    <nav aria-label="Main navigation">
      <ul class="nav__links">
        <li><a href="/#featured" class="nav__link">Top Games</a></li>
        <li><a href="/#categories" class="nav__link">Categories</a></li>
        <li><a href="/" class="nav__link">Reviews</a></li>
      </ul>
    </nav>
    <a href="#featured" class="nav__cta">Find Games</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 250, 247, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 60px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav__logo-mark {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--surface);
    background: var(--accent);
    padding: 0.25rem 0.4rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }

  .nav__logo-text {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .nav__links {
    display: flex;
    gap: 0.25rem;
    margin-inline-start: auto;
  }

  .nav__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-secondary);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav__link:hover {
    color: var(--ink);
    background: var(--border);
  }

  .nav__cta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--surface);
    background: var(--accent);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease;
    white-space: nowrap;
  }

  .nav__cta:hover {
    background: var(--accent-dim);
  }

  @media (max-width: 640px) {
    .nav__links { display: none; }
    .nav__logo-text { display: none; }
  }
</style>
